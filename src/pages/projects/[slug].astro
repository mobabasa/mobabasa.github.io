---
import "../../styles/base.css";
import { projects } from "../../data/projects.js";
import { timeline } from "../../data/timeline.js";
import { updates } from "../../data/updates.js";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;

const events = timeline
  .filter((item) => item.projectId === project.id)
  .sort((a, b) => new Date(a.date) - new Date(b.date));

const projectUpdates = updates
  .filter((item) => item.projectId === project.id)
  .sort((a, b) => new Date(a.date) - new Date(b.date));

const dateFormatter = new Intl.DateTimeFormat("en-US", { month: "long", day: "numeric", year: "numeric" });
const formatDate = (str) => dateFormatter.format(new Date(str));

const splitBody = (body) => body.split(/\n\n+/).filter(Boolean);

const hasCover = !!project.coverImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="description" content={project.description} />
    <meta property="og:title" content={`${project.title} — Mohamad Saab`} />
    <meta property="og:description" content={project.description} />
    {project.coverImage && <meta property="og:image" content={project.coverImage} />}
    <meta property="og:type" content="website" />
    <title>{project.title} — Mohamad Saab</title>
    {project.color && (
      <style define:vars={{ projectColor: project.color }}>
        :root { --project-color: var(--projectColor); }
      </style>
    )}
  </head>
  <body>
    <header class={`site-header project-header${hasCover ? " has-cover" : ""}`} style={project.color && !hasCover ? `--project-color: ${project.color}` : ""}>
      {hasCover && (
        <div class="project-cover">
          <img src={project.coverImage} alt={project.title} />
          <div class="project-cover__overlay"></div>
        </div>
      )}
      {!hasCover && <div class="project-header__bar" aria-hidden="true"></div>}
      <nav class="nav">
        <a class="logo" href="/">mohamad.saab</a>
        <div class="nav-links">
          <a href="/projects">← Projects</a>
          <a href="/timeline">Timeline</a>
        </div>
      </nav>
      <div class="hero">
        <p class="eyebrow">{project.category} · {project.role}</p>
        <h1>{project.title}</h1>
        <p class="subhead">{project.description}</p>
        <div class="project-meta-row">
          {project.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
          {project.status === "ongoing" && <span class="badge">Ongoing</span>}
        </div>
      </div>
    </header>

    <main>

      {/* Photo gallery — shown first for visual impact */}
      {project.photoSections && project.photoSections.length > 0 && (
        <section class="section fade-up">
          <div class="section-head">
            <h2>Photos</h2>
          </div>
          {project.photoSections.map((section) => (
            <div class="photo-section">
              <h3 class="photo-section__label">{section.label}</h3>
              <div class="photo-gallery">
                {section.images.map((src, i) => (
                  <a class="photo-gallery__item" href={src} target="_blank" rel="noreferrer">
                    <img src={src} alt={`${project.title} — ${section.label} ${i + 1}`} loading="lazy" />
                  </a>
                ))}
              </div>
            </div>
          ))}
        </section>
      )}
      {project.images && project.images.length > 0 && !project.photoSections && (
        <section class="section fade-up">
          <div class="section-head">
            <h2>Photos</h2>
          </div>
          <div class="photo-gallery">
            {project.images.map((src, i) => (
              <a class="photo-gallery__item" href={src} target="_blank" rel="noreferrer">
                <img src={src} alt={`${project.title} — photo ${i + 1}`} loading="lazy" />
              </a>
            ))}
          </div>
        </section>
      )}

      {/* YouTube embed */}
      {project.youtubeId && (
        <section class="section fade-up">
          <div class="video-embed">
            <iframe
              src={`https://www.youtube.com/embed/${project.youtubeId}`}
              title={project.title}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </section>
      )}

      {/* Local video clips */}
      {project.videos && project.videos.length > 0 && (
        <section class="section fade-up">
          <div class="section-head">
            <h2>Clips</h2>
          </div>
          <div class="video-grid">
            {project.videos.map((src) => {
              const poster = src.replace(/\.mp4$/i, "_poster.jpg");
              return (
                <div class="video-card" data-src={src} data-poster={poster}>
                  <button class="video-card__thumb" aria-label="Play video">
                    <img src={poster} alt="Video clip" loading="lazy" />
                    <span class="video-card__play-btn" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="6,3 20,12 6,21"/>
                      </svg>
                    </span>
                  </button>
                </div>
              );
            })}
          </div>
        </section>
      )}

      {/* Code snippets */}
      {project.codeSnippets && project.codeSnippets.length > 0 && (
        <section class="section fade-up">
          <details class="build-details" open>
            <summary class="build-details__summary">
              <h2>Code</h2>
              <span class="build-details__toggle" aria-hidden="true"></span>
            </summary>
            <div class="code-snippets">
              {project.codeSnippets.map((snippet) => (
                <div class="code-snippet">
                  <div class="code-snippet__header">
                    <span class="code-snippet__title">{snippet.title}</span>
                    <span class="code-snippet__lang">{snippet.language}</span>
                  </div>
                  <pre class="code-snippet__pre"><code set:text={snippet.code} /></pre>
                </div>
              ))}
            </div>
          </details>
        </section>
      )}

      {/* Build list — collapsible */}
      {project.buildList && (
        <section class="section fade-up">
          <details class="build-details" open>
            <summary class="build-details__summary">
              <h2>Build list</h2>
              <span class="build-details__toggle" aria-hidden="true"></span>
            </summary>
            <div class="build-list">
              {Object.entries(project.buildList).map(([category, items]) => (
                <div class="build-list__group">
                  <h3 class="build-list__category">{category}</h3>
                  <ul class="build-list__items">
                    {items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </details>
        </section>
      )}

      {/* Timeline milestones for this project */}
      {events.length > 0 && (
        <section class="section fade-up">
          <div class="section-head">
            <h2>Timeline milestones</h2>
            <a class="text-link" href="/timeline">View full timeline →</a>
          </div>
          <ol class="project-events">
            {events.map((event) => (
              <li class="project-event" style={project.color ? `--project-color: ${project.color}` : ""}>
                <span class="project-event__dot" aria-hidden="true"></span>
                <div class="project-event__content">
                  <p class="project-event__meta">{formatDate(event.date)}</p>
                  <h3>{event.title}</h3>
                  <p class="project-event__summary">{event.summary}</p>
                  {event.footageUrl && (
                    <a class="text-link" href={event.footageUrl} target="_blank" rel="noreferrer">
                      Footage ↗
                    </a>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      {/* Blog-style update posts */}
      <section class="section section-alt fade-up">
        <div class="section-head">
          <h2>Project log</h2>
        </div>
        {projectUpdates.length > 0 ? (
          <ol class="update-feed">
            {projectUpdates.map((update) => (
              <li class="update-post">
                <header class="update-post__header">
                  <time class="update-post__date" datetime={update.date}>
                    {formatDate(update.date)}
                  </time>
                  <h3 class="update-post__title">{update.title}</h3>
                </header>
                <div class="update-post__body">
                  {splitBody(update.body).map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </li>
            ))}
          </ol>
        ) : (
          <p class="subhead">No log entries yet — check back later.</p>
        )}
      </section>
    </main>

    <footer class="site-footer">
      <p>
        <a class="text-link" href="/projects">← All projects</a>
        &nbsp;·&nbsp;
        <a class="text-link" href="mailto:mobabasa@gmail.com">mobabasa@gmail.com</a>
      </p>
    </footer>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
      <button class="lightbox__close" id="lightbox-close" aria-label="Close">&times;</button>
      <button class="lightbox__nav lightbox__nav--prev" id="lightbox-prev" aria-label="Previous photo">&#8249;</button>
      <button class="lightbox__nav lightbox__nav--next" id="lightbox-next" aria-label="Next photo">&#8250;</button>
      <div class="lightbox__img-wrap" id="lightbox-img-wrap">
        <img id="lightbox-img" src="" alt="" />
      </div>
      <div class="lightbox__counter" id="lightbox-counter"></div>
    </div>

    <script>
      const observer = new IntersectionObserver(
        (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add("is-visible"); observer.unobserve(e.target); } }),
        { threshold: 0.05 }
      );
      document.querySelectorAll(".fade-up").forEach((el) => observer.observe(el));
    </script>
    <script>
      // ── Video card: click thumb → swap in autoplay video ──────────────
      document.querySelectorAll(".video-card").forEach((card) => {
        const btn = card.querySelector(".video-card__thumb");
        if (!btn) return;
        btn.addEventListener("click", () => {
          const src = card.dataset.src;
          const poster = card.dataset.poster;
          const video = document.createElement("video");
          video.src = src;
          video.poster = poster;
          video.controls = true;
          video.autoplay = true;
          video.playsInline = true;
          video.className = "video-card__player";
          card.replaceChildren(video);
          video.play().catch(() => {});
        });
      });

      // ── Enhanced lightbox: nav + swipe + zoom ─────────────────────────
      const lightbox    = document.getElementById("lightbox");
      const lightboxImg = document.getElementById("lightbox-img");
      const imgWrap     = document.getElementById("lightbox-img-wrap");
      const counter     = document.getElementById("lightbox-counter");
      const btnClose    = document.getElementById("lightbox-close");
      const btnPrev     = document.getElementById("lightbox-prev");
      const btnNext     = document.getElementById("lightbox-next");

      const gallery = [...document.querySelectorAll(".photo-gallery__item")];
      let idx = 0;
      let zoomed = false;

      const resetZoom = () => {
        zoomed = false;
        lightboxImg.style.transform = "";
        lightboxImg.style.cursor = gallery.length > 1 ? "" : "";
      };

      const openAt = (i) => {
        idx = (i + gallery.length) % gallery.length;
        const link = gallery[idx];
        lightboxImg.src = link.href;
        lightboxImg.alt = link.querySelector("img")?.alt || "";
        resetZoom();
        counter.textContent = gallery.length > 1 ? `${idx + 1} / ${gallery.length}` : "";
        btnPrev.style.opacity = gallery.length > 1 ? "1" : "0";
        btnNext.style.opacity = gallery.length > 1 ? "1" : "0";
        btnPrev.style.pointerEvents = gallery.length > 1 ? "" : "none";
        btnNext.style.pointerEvents = gallery.length > 1 ? "" : "none";
        lightbox.classList.add("is-open");
        document.body.style.overflow = "hidden";
      };

      const close = () => {
        lightbox.classList.remove("is-open");
        document.body.style.overflow = "";
        setTimeout(() => { lightboxImg.src = ""; }, 200);
      };

      gallery.forEach((link, i) => {
        link.addEventListener("click", (e) => { e.preventDefault(); openAt(i); });
      });

      btnClose.addEventListener("click", close);
      btnPrev.addEventListener("click", (e) => { e.stopPropagation(); openAt(idx - 1); });
      btnNext.addEventListener("click", (e) => { e.stopPropagation(); openAt(idx + 1); });

      lightbox.addEventListener("click", (e) => {
        if (e.target === lightbox || e.target === imgWrap) close();
      });

      // Keyboard
      document.addEventListener("keydown", (e) => {
        if (!lightbox.classList.contains("is-open")) return;
        if (e.key === "Escape")      close();
        if (e.key === "ArrowLeft")   openAt(idx - 1);
        if (e.key === "ArrowRight")  openAt(idx + 1);
      });

      // Double-click / double-tap zoom
      lightboxImg.addEventListener("dblclick", () => {
        zoomed = !zoomed;
        lightboxImg.style.transform = zoomed ? "scale(2.2)" : "";
        lightboxImg.style.cursor    = zoomed ? "zoom-out" : "zoom-in";
      });

      // Touch swipe
      let tx = 0, ty = 0;
      lightbox.addEventListener("touchstart", (e) => {
        tx = e.touches[0].clientX;
        ty = e.touches[0].clientY;
      }, { passive: true });
      lightbox.addEventListener("touchend", (e) => {
        const dx = e.changedTouches[0].clientX - tx;
        const dy = e.changedTouches[0].clientY - ty;
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 45) {
          if (dx < 0) openAt(idx + 1); else openAt(idx - 1);
        }
      }, { passive: true });
    </script>
  </body>
</html>
